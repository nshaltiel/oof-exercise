rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      // Anyone can read sessions (teachers need shortCode lookup)
      allow read: if true;
      // Only authenticated users can create sessions
      allow create: if request.auth != null;
      // Only the principal who created it can update/delete
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.principalUid;

      match /notes/{noteId} {
        // Anyone can create and read notes
        allow create: if true;
        allow read: if true;
        // Teachers can update their own notes (sorting) OR principal can update
        allow update: if request.resource.data.teacherToken == resource.data.teacherToken
          || (request.auth != null
              && get(/databases/$(database)/documents/sessions/$(sessionId)).data.principalUid == request.auth.uid);
        // Only principal can delete
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.principalUid == request.auth.uid;
      }
    }
  }
}
