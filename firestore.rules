rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      // Only the principal who created it can read/write
      allow read, write: if request.auth != null && request.auth.uid == resource.data.principalUid;
      // Allow creation if authenticated
      allow create: if request.auth != null;

      match /notes/{noteId} {
        // Anyone can create notes (teachers are anonymous)
        allow create: if true;
        // Teachers can update their own notes (for sorting)
        allow update: if request.resource.data.teacherToken == resource.data.teacherToken;
        // Principal can read all notes and update/delete them
        allow read, update, delete: if request.auth != null &&
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.principalUid == request.auth.uid;
      }
    }
  }
}
